{
  "name": "@vef-framework-react/starter",
  "version": "2.6.0",
  "private": false,
  "description": "Starter for VEF framework",
  "keywords": [
    "vef",
    "framework",
    "react",
    "starter"
  ],
  "homepage": "https://vef.ilxqx.com",
  "license": "Apache-2.0",
  "author": {
    "name": "Venus",
    "email": "iweixiaopeng@163.com",
    "url": "https://github.com/ilxqx"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "vef": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@emotion/react": "^11.14.0",
    "@tanem/react-nprogress": "^6.0.3",
    "compare-versions": "^6.1.1",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@tanstack/react-router": "^1.170.15",
    "@vef-framework-react/components": "workspace:*",
    "@vef-framework-react/core": "workspace:*",
    "@vef-framework-react/hooks": "workspace:*",
    "@vef-framework-react/shared": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1",
    "@vef-framework-react/components": ">=2",
    "@vef-framework-react/core": ">=2",
    "@vef-framework-react/hooks": ">=2",
    "@vef-framework-react/shared": ">=2",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
