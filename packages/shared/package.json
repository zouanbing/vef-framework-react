{
  "name": "@vef-framework-react/shared",
  "type": "module",
  "version": "2.4.2",
  "private": false,
  "packageManager": "pnpm@11.1.2",
  "description": "Shared utilities for VEF framework",
  "author": {
    "name": "Venus",
    "email": "iweixiaopeng@163.com",
    "url": "https://github.com/ilxqx"
  },
  "license": "Apache-2.0",
  "homepage": "https://vef.ilxqx.com",
  "keywords": ["vef", "framework", "react", "shared"],
  "sideEffects": false,
  "exports": {
    ".": {
      "vef": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "files": ["dist"],
  "engines": {
    "node": ">=22.x"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "vite build"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pinyin-pro/data": "^1.3.1",
    "colord": "^2.9.3",
    "dayjs": "^1.11.21",
    "jsencrypt": "^3.5.4",
    "klona": "^2.0.6",
    "mitt": "^3.0.1",
    "path-browserify": "^1.0.1",
    "pinyin-pro": "^3.28.1",
    "qs": "^6.15.2",
    "radashi": "^12.9.0",
    "stacktrace-js": "^2.0.2",
    "tiny-lru": "^13.0.0",
    "type-fest": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/path-browserify": "^1.0.3",
    "@types/qs": "^6.15.1"
  }
}
