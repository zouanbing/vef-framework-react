{
  "name": "@vef-framework-react/approval-flow-editor",
  "version": "2.6.0",
  "private": false,
  "description": "Approval flow editor for VEF framework",
  "keywords": [
    "vef",
    "framework",
    "react",
    "approval",
    "flow",
    "editor"
  ],
  "homepage": "https://vef.ilxqx.com",
  "license": "Apache-2.0",
  "author": {
    "name": "Venus",
    "email": "iweixiaopeng@163.com",
    "url": "https://github.com/ilxqx"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "vef": "./src/index.ts",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/es/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/es/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@vef-framework-react/components": "workspace:*",
    "@vef-framework-react/core": "workspace:*",
    "@vef-framework-react/expression": "workspace:*",
    "@vef-framework-react/shared": "workspace:*",
    "@xyflow/react": "^12.11.0",
    "dayjs": "^1.11.0",
    "elkjs": "^0.11.1",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "react": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.x"
  },
  "publishConfig": {
    "access": "public"
  }
}
