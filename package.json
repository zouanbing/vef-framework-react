{
  "name": "vef-framework-react",
  "type": "module",
  "version": "2.4.2",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "description": "Blazing powerful framework made by Venus",
  "author": {
    "name": "Venus",
    "email": "iweixiaopeng@163.com",
    "url": "https://github.com/ilxqx"
  },
  "license": "Apache-2.0",
  "homepage": "https://vef.ilxqx.com",
  "keywords": ["vef", "framework", "react", "ui"],
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "pnpm format:pkg",
    "postuninstall": "pnpm format:pkg",
    "sync-meta": "tsx scripts/sync-meta.ts",
    "deps:check": "tsx scripts/check-deps.ts",
    "deps:check:apply": "tsx scripts/check-deps.ts --apply",
    "clean": "pnpm --filter=./packages/* run clean",
    "clean:modules": "rm -rf node_modules packages/*/node_modules playground/node_modules pnpm-lock.yaml",
    "build": "pnpm --filter=./packages/* run build",
    "typecheck": "pnpm --filter=./packages/* run typecheck",
    "typecheck:approval-flow-editor": "pnpm --filter=./packages/approval-flow-editor run typecheck",
    "typecheck:components": "pnpm --filter=./packages/components run typecheck",
    "typecheck:core": "pnpm --filter=./packages/core run typecheck",
    "typecheck:dev": "pnpm --filter=./packages/dev run typecheck",
    "typecheck:expression": "pnpm --filter=./packages/expression run typecheck",
    "typecheck:form-editor": "pnpm --filter=./packages/form-editor run typecheck",
    "typecheck:hooks": "pnpm --filter=./packages/hooks run typecheck",
    "typecheck:starter": "pnpm --filter=./packages/starter run typecheck",
    "typecheck:shared": "pnpm --filter=./packages/shared run typecheck",
    "build:components": "pnpm --filter=./packages/components run build",
    "build:core": "pnpm --filter=./packages/core run build",
    "build:dev": "pnpm --filter=./packages/dev run build",
    "build:expression": "pnpm --filter=./packages/expression run build",
    "build:hooks": "pnpm --filter=./packages/hooks run build",
    "build:starter": "pnpm --filter=./packages/starter run build",
    "build:shared": "pnpm --filter=./packages/shared run build",
    "version:patch": "pnpm version patch --no-git-tag-version && pnpm --filter=./packages/* exec pnpm version patch --no-git-tag-version",
    "version:minor": "pnpm version minor --no-git-tag-version && pnpm --filter=./packages/* exec pnpm version minor --no-git-tag-version",
    "version:major": "pnpm version major --no-git-tag-version && pnpm --filter=./packages/* exec pnpm version major --no-git-tag-version",
    "pub": "pnpm --filter=./packages/* publish --force",
    "unpub": "tsx scripts/unpublish.ts",
    "rename-fonts": "pnpm --filter=./packages/components run rename-fonts",
    "format:pkg": "eslint --fix \"**/package.json\"",
    "release:patch": "pnpm version:patch && pnpm format:pkg && pnpm clean && pnpm build && pnpm pub",
    "release:minor": "pnpm version:minor && pnpm format:pkg && pnpm clean && pnpm build && pnpm pub",
    "release:major": "pnpm version:major && pnpm format:pkg && pnpm clean && pnpm build && pnpm pub",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx,json,jsonc,md,mdx}\" --fix",
    "test:coverage": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run --coverage",
    "test:watch": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest",
    "playground": "pnpm --filter=./playground dev",
    "build:playground": "pnpm --filter=./playground build",
    "preview:playground": "pnpm --filter=./playground preview"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "^5.8.13",
    "@eslint-react/kit": "^5.8.13",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@rollup/pluginutils": "^5.4.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/utils": "^8.60.1",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "chalk": "^5.6.2",
    "consola": "^3.4.2",
    "eslint": "^10.4.1",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-lite": "^0.6.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-dom": "^5.8.13",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-jsx": "^5.8.13",
    "eslint-plugin-react-naming-convention": "^5.8.13",
    "eslint-plugin-react-web-api": "^5.8.13",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "radashi": "^12.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,jsonc,md,mdx,html}": "eslint --fix"
  }
}
